# ⚠️  VALORES DUMMY — SUBSTITUA COM SEUS PRÓPRIOS
# NUNCA faça commit de .env.local! Está no .gitignore
# Obter valores reais em: https://supabase.com/dashboard, https://console.cloud.google.com

# Supabase (https://supabase.com/dashboard)
# - URL: Project Settings → API → Project URL
# - ANON_KEY: Project Settings → API → Project API keys → anon
# - SERVICE_ROLE_KEY: Project Settings → API → Project API keys → service_role (SECRETO!)
NEXT_PUBLIC_SUPABASE_URL=https://CHANGEME_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=CHANGEME_ANON_KEY_LONG_STRING
SUPABASE_SERVICE_ROLE_KEY=CHANGEME_SERVICE_ROLE_KEY_LONG_STRING

# Google Business Profile API OAuth
# Gerar em: https://console.cloud.google.com/
# 1. Create Project
# 2. Enable Google Business Profile API
# 3. Create OAuth 2.0 credentials (Desktop app)
# 4. Download JSON e extrair client_id, client_secret
GOOGLE_CLIENT_ID=CHANGEME_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGEME_CLIENT_SECRET_FROM_GOOGLE
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# Google Token Encryption Key (para criptografar access tokens em repouso)
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Deve ter 64 caracteres hex (32 bytes)
GOOGLE_TOKEN_ENCRYPTION_KEY=CHANGEME_64_HEX_CHARS_SHOULD_BE_32_BYTES_64_CHARS

# IA APIs
# - Anthropic: https://console.anthropic.com/
# - OpenAI: https://platform.openai.com/api-keys
# - Google AI: https://aistudio.google.com/apikey
ANTHROPIC_API_KEY=CHANGEME_ANTHROPIC_API_KEY
OPENAI_API_KEY=CHANGEME_OPENAI_API_KEY
GEMINI_API_KEY=CHANGEME_GEMINI_API_KEY

# Pagamento — Mercado Pago (https://www.mercadopago.com/developers/pt_BR)
# ACCESS_TOKEN: Gerar em Credenciais → Tokens
# PUBLIC_KEY: Chave pública (pode ser exposta)
# WEBHOOK_TOKEN: String aleatória para validar webhooks (salve seguro!)
MERCADOPAGO_ACCESS_TOKEN=CHANGEME_ACCESS_TOKEN_FROM_MP
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=CHANGEME_PUBLIC_KEY_FROM_MP
MERCADOPAGO_WEBHOOK_TOKEN=CHANGEME_SECURE_RANDOM_STRING_FOR_WEBHOOK_VALIDATION

# Email (https://resend.com/api-keys)
RESEND_API_KEY=CHANGEME_RESEND_API_KEY

# App URL (para redirects OAuth)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://vitrine-ai.br (quando deploy)

# === SEGURANÇA ===

# Rate Limiting — Upstash Redis (https://console.upstash.com/)
# Redis sem servidor para rate limiting de APIs (cargas x por minuto)
# Gerar em: https://console.upstash.com/redis/new
# Copiar: "Rest API URL" e "Rest Token"
UPSTASH_REDIS_REST_URL=CHANGEME_UPSTASH_REST_URL
UPSTASH_REDIS_REST_TOKEN=CHANGEME_UPSTASH_REST_TOKEN

# Cron Jobs (Token refresh, sincronização, etc)
# Gerar via: openssl rand -hex 32
# Use para validar requisições do cron interno (Vercel)
CRON_SECRET=CHANGEME_CRON_SECRET_TOKEN_64_HEX_CHARS

